{
    "databases": {
        "hidden" : [
            "information_schema",
            "mysql",
            "performance_schema",
            "sys"
        ]
    },
    "tables": {
        "query": {
            "defaultLimit": 100,
            "absolutLimit": 1000,
            "easyBuilder": true
        },
        "defaultPage": "datas",
        "searchForEmpty": false,
        "showBooleanAsCheck": true
    },
    "appDisplay": {
        "displayMenu": true,
        "dateFormat": "yyyy-LL-dd",
        "displaySQLRequestInDatasView": true,
        "displayKeyboardShortcut": true
    },
    "CSV": {
        "defaultFormat": {
            "valueSeparator": ",",
            "rowSeparator": "\n"
        }
    },
    "fuzzySearch": {
        "enabled": true
    }
}